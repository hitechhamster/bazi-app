# Supabase — copy these from your Supabase project settings
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# Google Gemini AI
GEMINI_API_KEY=

# Demo chart route (/demo)
# Set this to a profile UUID from your Supabase profiles table.
# Pick any profile with base_report_status = 'done' so the demo looks complete.
# The profile's real name is hidden from visitors; only chart data is shown.
DEMO_PROFILE_ID=
