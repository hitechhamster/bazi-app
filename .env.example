# Supabase — copy these from your Supabase project settings
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# Geocoding (OpenCage) — https://opencagedata.com
OPENCAGE_API_KEY=

# AI (Gemini) — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Demo profile IDs (production only)
# Set each to a profile UUID from your Supabase profiles table for that locale.
# Pick profiles with base_report_status = 'done' so the demo looks complete.
# The profile's real name is hidden from visitors; only chart data is shown.
DEMO_PROFILE_ID_EN=
DEMO_PROFILE_ID_ZH_CN=
DEMO_PROFILE_ID_ZH_TW=

# Internal secret for server-to-server chained generation calls
# Generate with: openssl rand -hex 32
# Must match across all invocations in the same deployment.
INTERNAL_GENERATE_SECRET=

# Network proxy (dev only, optional)
# Only needed if your local machine requires a proxy to reach external APIs.
HTTPS_PROXY=
